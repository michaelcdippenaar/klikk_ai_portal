# Copy this file to .env and fill in real values
# .env is gitignored — never commit secrets

# --- AI Provider: "anthropic" or "openai" ---
AI_PROVIDER=openai

# Anthropic Claude API (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# VoyageAI Embeddings (https://www.voyageai.com)
VOYAGE_API_KEY=pa-...

# TM1 Server (same machine — 192.168.1.194)
TM1_HOST=192.168.1.194
TM1_PORT=44414
TM1_USER=admin
TM1_PASSWORD=
TM1_SSL=false

# PostgreSQL — klikk_financials_v4 (Xero GL source data)
PG_FINANCIALS_HOST=192.168.1.235
PG_FINANCIALS_PORT=5432
PG_FINANCIALS_DB=klikk_financials_v4
PG_FINANCIALS_USER=klikk_user
PG_FINANCIALS_PASSWORD=

# PostgreSQL — klikk_bi_etl (BI metrics + RAG vector store)
PG_BI_HOST=192.168.1.235
PG_BI_PORT=5432
PG_BI_DB=klikk_bi_etl
PG_BI_USER=klikk_user
PG_BI_PASSWORD=

# Web Search (DuckDuckGo — free, no API key needed)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# Google Drive (optional — set up a service account, share folder with it)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_FOLDER_IDS=
